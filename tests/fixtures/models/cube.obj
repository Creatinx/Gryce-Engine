# Simple unit cube
# 8 vertices, 6 faces (12 triangles)

v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

vn  0.0  0.0 -1.0
vn  0.0  0.0  1.0
vn -1.0  0.0  0.0
vn  1.0  0.0  0.0
vn  0.0 -1.0  0.0
vn  0.0  1.0  0.0

vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# front face (z = -0.5)
f 1/1/1 2/2/1 3/3/1
f 1/1/1 3/3/1 4/4/1

# back face (z = 0.5)
f 6/1/2 5/2/2 8/3/2
f 6/1/2 8/3/2 7/4/2

# left face (x = -0.5)
f 5/1/3 1/2/3 4/3/3
f 5/1/3 4/3/3 8/4/3

# right face (x = 0.5)
f 2/1/4 6/2/4 7/3/4
f 2/1/4 7/3/4 3/4/4

# bottom face (y = -0.5)
f 5/1/5 6/2/5 2/3/5
f 5/1/5 2/3/5 1/4/5

# top face (y = 0.5)
f 4/1/6 3/2/6 7/3/6
f 4/1/6 7/3/6 8/4/6
